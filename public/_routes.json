{
  "version": 1,
  "include": ["/*"],
  "exclude": [
    "/assets/*",
    "/favicon*",
    "/manifest.json",
    "/site.webmanifest",
    "/robots.txt",
    "/sitemap.xml"
  ],
  "headers": {
    "/*": {
      "X-Frame-Options": "DENY",
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    }
  },
  "routing": {
    "/*": "/index.html"
  }
}